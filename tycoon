-- ========== CORE LOGIC ==========
local function getTycoon()
    for _, v in pairs(workspace:GetChildren()) do
        if v:IsA("Model") and (v.Name:lower():find("tycoon") or v.Name:lower():find("energy")) then
            return v
        end
    end
    return nil
end

local function getDrops(tycoon)
    local drops = {}
    if not tycoon then return drops end
    for _, v in pairs(tycoon:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name:lower():find("drop") or v.Name:lower():find("coin") or v.Name:lower():find("money") or v.Name:lower():find("gem") or v.Name:lower():find("crystal")) then
            table.insert(drops, v)
        end
    end
    return drops
end

local function getButtons(tycoon)
    local buttons = {}
    if not tycoon then return buttons end
    for _, v in pairs(tycoon:GetDescendants()) do
        if v:IsA("ClickDetector") or (v:IsA("BasePart") and v.Name:lower():find("button")) then
            table.insert(buttons, v)
        end
    end
    return buttons
end

