-- Rainbow Color Function
local function getRainbowColor(t)
    local r = math.sin(t * 2) * 0.5 + 0.5
    local g = math.sin(t * 2 + 2) * 0.5 + 0.5
    local b = math.sin(t * 2 + 4) * 0.5 + 0.5
    return Color3.new(r, g, b)
end

