createToggle("Money x10000", "Nhân số tiền hiện tại lên 10000 lần", function(enabled)
    features.moneyMultiplier = enabled
    
    if enabled then
        spawn(function()
            while features.moneyMultiplier do
                wait(0.1)
                pcall(function()
                    -- Tìm và thao tác với số tiền
                    local leaderstats = player:FindFirstChild("leaderstats")
                    if leaderstats then
                        for _, stat in pairs(leaderstats:GetChildren()) do
                            if stat:IsA("IntValue") or stat:IsA("NumberValue") then
                                if stat.Name:lower():match("money") or stat.Name:lower():match("cash") or stat.Name:lower():match("coin") then
                                    -- Lưu giá trị gốc và nhân lên
                                    local originalValue = stat.Value
                                    stat.Value = originalValue * 10000
                                    
                                    -- Hook metamethod để mọi thay đổi đều được nhân
                                    local mt = getrawmetatable and getrawmetatable(game) or nil
                                    if mt and setreadonly then
                                        setreadonly(mt, false)
                                        local oldIndex = mt.__index
                                        mt.__index = function(t, k)
                                            if t == stat and k == "Value" then
                                                return oldIndex(t, k) * 10000
                                            end
                                            return oldIndex(t, k)
                                        end
                                    end
                                end
                            end
                        end
                    end
                    
                    -- Thử fire remote để thêm tiền
                    for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
                        if remote:IsA("RemoteEvent") then
                            if remote.Name:lower():match("add") or remote.Name:lower():match("give") or remote.Name:lower():match("earn") then
                                remote:FireServer(999999999)
                            end
                        end
                    end
                end)
            end
        end)
    end
end)

