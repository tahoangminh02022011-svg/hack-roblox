-- FEATURE 4: Rainbow ESP
createToggle("Rainbow ESP", "Hiển thị người chơi với khung cầu vồng", function(enabled)
    features.rainbowESP = enabled
    
    if enabled then
        -- Tạo ESP cho mỗi người chơi
        local function createESP(targetPlayer)
            if targetPlayer == player then return end
            
            -- Xóa ESP cũ nếu có
            if espObjects[targetPlayer] then
                for _, obj in pairs(espObjects[targetPlayer]) do
                    obj:Remove()
                end
            end
            
            espObjects[targetPlayer] = {}
            
            -- Tạo khung box ESP sử dụng Drawing API
            local box = Drawing.new("Square")
            box.Visible = false
            box.Thickness = 2
            box.Filled = false
            box.Transparency = 1
            espObjects[targetPlayer].box = box
            
            -- Tạo vòng tròn ở tâm (0-5cm tương đương 10-50 pixel tùy khoảng cách)
            local centerCircle = Drawing.new("Circle")
            centerCircle.Visible = false
            centerCircle.Thickness = 2
            centerCircle.Filled = true
            centerCircle.NumSides = 32
            centerCircle.Radius = 15 -- Kích thước có thể điều chỉnh
            espObjects[targetPlayer].circle = centerCircle
            
            -- Tên người chơi
            local nameTag = Drawing.new("Text")
            nameTag.Visible = false
            nameTag.Size = 16
            nameTag.Center = true
            nameTag.Outline = true
            nameTag.Text = targetPlayer.Name
            espObjects[targetPlayer].name = nameTag
            
            -- Khoảng cách
            local distanceTag = Drawing.new("Text")
            distanceTag.Visible = false
            distanceTag.Size = 14
            distanceTag.Center = true
            distanceTag.Outline = true
            espObjects[targetPlayer].distance = distanceTag
        end
        
        -- Cập nhật ESP mỗi frame
        espConnection = RunService.RenderStepped:Connect(function()
            local rainbowColor = getRainbowColor(tick())
            
            for _, targetPlayer in pairs(Players:GetPlayers()) do
                if targetPlayer ~= player then
                    if not espObjects[targetPlayer] then
                        createESP(targetPlayer)
                    end
                    
                    local character = targetPlayer.Character
                    if character then
                        local hrp = character:FindFirstChild("HumanoidRootPart")
                        local head = character:FindFirstChild("Head")
                        local humanoid = character:FindFirstChild("Humanoid")
                        
                        if hrp and head and humanoid then
                            local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
                            local headPos = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                            local legPos = camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                            
                            if onScreen then
                                local box = espObjects[targetPlayer].box
                                local circle = espObjects[targetPlayer].circle
                                local name = espObjects[targetPlayer].name
                                local dist = espObjects[targetPlayer].distance
                                
                                -- Tính toán kích thước box
                                local boxHeight = math.abs(headPos.Y - legPos.Y)
                                local boxWidth = boxHeight * 0.6
                                
                                -- Cập nhật box
                                box.Size = Vector2.new(boxWidth, boxHeight)
                                box.Position = Vector2.new(pos.X - boxWidth/2, pos.Y - boxHeight/2)
                                box.Color = rainbowColor
                                box.Visible = true
                                
                                -- Cập nhật vòng tròn tâm (cầu vồng)
                                circle.Position = Vector2.new(pos.X, pos.Y)
                                circle.Color = rainbowColor
                                circle.Radius = math.clamp(boxWidth * 0.15, 5, 25) -- 0-5cm tương đối
                                circle.Visible = true
                                
                                -- Cập nhật tên
                                name.Position = Vector2.new(pos.X, headPos.Y - 25)
                                name.Color = rainbowColor
                                name.Visible = true
                                
                                -- Cập nhật khoảng cách
                                local distance = (hrp.Position - camera.CFrame.Position).Magnitude
                                distanceTag.Position = Vector2.new(pos.X, legPos.Y + 5)
                                distanceTag.Text = math.floor(distance) .. "m"
                                distanceTag.Color = rainbowColor
                                distanceTag.Visible = true
                            else
                                -- Ẩn nếu không trong màn hình
                                espObjects[targetPlayer].box.Visible = false
                                espObjects[targetPlayer].circle.Visible = false
                                espObjects[targetPlayer].name.Visible = false
                                espObjects[targetPlayer].distance.Visible = false
                            end
                        end
                    end
                end
            end
        end)
        
        -- Tạo ESP cho người chơi hiện có
        for _, p in pairs(Players:GetPlayers()) do
            createESP(p)
        end
        
        -- Tạo ESP cho người chơi mới
        Players.PlayerAdded:Connect(createESP)
        
        -- Xóa ESP khi người chơi rời đi
        Players.PlayerRemoving:Connect(function(p)
            if espObjects[p] then
                for _, obj in pairs(espObjects[p]) do
                    obj:Remove()
                end
                espObjects[p] = nil
            end
        end)
        
    else
        -- Tắt ESP
        if espConnection then
            espConnection:Disconnect()
            espConnection = nil
        end
        
        for _, objects in pairs(espObjects) do
            for _, obj in pairs(objects) do
                obj:Remove()
            end
        end
        espObjects = {}
    end
end)

